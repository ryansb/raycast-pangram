{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": ["src"],
  "compilerOptions": {
    "lib": ["ES2020"],
    "module": "CommonJS",
    "target": "ES2020",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "noUnusedLocals": true,
    "paths": {
      "@raycast/api": ["./node_modules/@raycast/api"]
    }
  }
}
